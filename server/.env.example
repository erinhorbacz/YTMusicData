# Copy to server/.env and fill in.
#
# YouTube Data API v3 key — used only to fetch exact track durations.
# The app runs fine without it (minutes are estimated at 3m45s per play
# until enrichment fills in real durations from YT Music search results).
# Create one at https://console.cloud.google.com/apis/credentials
# (YT_DATA_API_KEY is accepted as an alternative name for the same thing.)
YOUTUBE_API_KEY=

# Port the API server listens on (5001 avoids macOS AirPlay on 5000)
PORT=5001

# Set to false to stop the enrichment job from auto-starting at boot
ENRICH_ON_BOOT=true
